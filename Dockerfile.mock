# Use the official lightweight Mockoon CLI image
FROM mockoon/cli:latest

# Copy your configuration file
COPY mockoon.json /data/mockoon.json

# Let Render know the entrypoint will listen on port 10000
EXPOSE 10000

# 💡 FORCE OVERRIDE: We bypass the default entrypoint to map the port forcefully
ENTRYPOINT ["mockoon-cli", "start", "--hostname", "0.0.0.0", "--data", "/data/mockoon.json", "--port", "10000"]